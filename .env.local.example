# PostgreSQL Neon — utiliser l'URL pooled pour serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js v5 — générer avec : openssl rand -base64 32
AUTH_SECRET="remplacer-par-32-octets-aleatoires"

# Optionnel en local, requis en production
